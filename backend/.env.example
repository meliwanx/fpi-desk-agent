# Muse Backend Configuration

# Required: OpenRouter API key
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Local OpenAI-compatible endpoint (optional)
# OPENYAK_LOCAL_BASE_URL=http://localhost:11434/v1

# Database (default: SQLite in ./data/)
# DATABASE_URL=sqlite+aiosqlite:///./data/muse.db

# Server
# HOST=0.0.0.0
# PORT=8000
# DEBUG=false

# Project directory (default: current directory)
# PROJECT_DIR=.

# Sandbox execution
# Default is local Codex-like sandboxing:
# - macOS: Seatbelt via sandbox-exec
# - Linux/WSL2: bubblewrap
# - unsupported platforms: auto falls back to host execution
# OPENYAK_SANDBOX_MODE=auto
# OPENYAK_SANDBOX_PROVIDER=local
