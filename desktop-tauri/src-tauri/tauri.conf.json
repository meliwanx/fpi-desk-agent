{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "fpi-agent",
  "identifier": "com.openyak.desktop",
  "version": "1.5.0",
  "build": {
    "frontendDist": "../../frontend/out",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm --prefix .. run build:frontend && npm --prefix .. run build:backend",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "fpi-agent",
        "width": 1360,
        "height": 840,
        "minWidth": 1024,
        "minHeight": 640,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 19,
          "y": 32
        },
        "hiddenTitle": true,
        "visible": false,
        "center": true,
        "transparent": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://localhost:* http://127.0.0.1:* http://[::1]:* http://120.26.208.161:5201 http://fpiagent.hangzhoupuyu.work https://*; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; script-src 'self' 'unsafe-inline'; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "../../backend/dist/openyak-backend": "backend",
      "../../backend/resources/nodejs": "nodejs"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "installer-hooks.nsh",
        "languages": [
          "SimpChinese"
        ],
        "displayLanguageSelector": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "Developer ID Application: rui dong (53BDDF5YZM)",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "openyak"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://fpiagent.hangzhoupuyu.work/api/app/update-manifest/{{target}}/{{arch}}/{{current_version}}?bundle={{bundle_type}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzMDUyQzY2MjhGNUYwRjIKUldUeThQVW9aaXdGSTRsVzRXL0MvV1BTeUZWSmp5SlR6RThWdU9lMzQ2Y3IvWndFSDYrTVk0LzUK"
    },
    "shell": {
      "open": true
    }
  }
}
